        {
          "text": " ",
          "normalizedText": " ",
          "type": "Whitespace",
          "start": 7,
          "end": 8
        },
        {
          "text": "комп’ютер",
          "normalizedText": "комп’ютер",
          "type": "Word",
          "start": 8,
          "end": 17
        }
      ]
    },
    {
