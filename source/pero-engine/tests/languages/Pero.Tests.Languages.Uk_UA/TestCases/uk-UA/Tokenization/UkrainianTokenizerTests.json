        {
          "text": " ",
          "normalizedText": " ",
          "type": "Whitespace",
          "start": 4,
          "end": 5
        },
        {
          "text": "та",
          "normalizedText": "та",
          "type": "Word",
          "start": 5,
          "end": 7
