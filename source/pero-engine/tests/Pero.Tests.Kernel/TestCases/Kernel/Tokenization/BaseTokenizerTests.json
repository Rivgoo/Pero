    {
      "name": "Number Grouping",
      "input": "Item 42.",
      "expected": [
        {
          "text": "Item",
          "normalizedText": "item",
          "type": "Word",
          "start": 0,
          "end": 4
        },
        {
          "text": " ",
          "normalizedText": " ",
          "type": "Whitespace",
          "start": 4,
          "end": 5
        },
        {
          "text": "42",
          "normalizedText": "42",
          "type": "Number",
          "start": 5,
          "end": 7
        },
        {
          "text": ".",
          "normalizedText": ".",
          "type": "Punctuation",
          "start": 7,
          "end": 8
        }
      ]
    },
    {
      "name": "Exact Ellipsis Processing",
      "input": "Wait...",
      "expected": [
        {
          "text": "Wait",
          "normalizedText": "wait",
          "type": "Word",
          "start": 0,
          "end": 4
        },
        {
          "text": "...",
          "normalizedText": "...",
          "type": "Punctuation",
          "start": 4,
          "end": 7
        }
      ]
    },
    {
      "name": "Overextended Ellipsis",
      "input": "Wait....",
      "expected": [
        {
          "text": "Wait",
          "normalizedText": "wait",
          "type": "Word",
          "start": 0,
          "end": 4
        },
        {
          "text": "...",
          "normalizedText": "...",
          "type": "Punctuation",
          "start": 4,
          "end": 7
        },
        {
          "text": ".",
          "normalizedText": ".",
          "type": "Punctuation",
          "start": 7,
          "end": 8
        }
      ]
    },
    {
      "name": "Surrogate Pairs (Emojis)",
      "input": "Go 🚀!",
      "expected": [
        {
          "text": "Go",
          "normalizedText": "go",
          "type": "Word",
          "start": 0,
          "end": 2
        },
        {
          "text": " ",
          "normalizedText": " ",
          "type": "Whitespace",
          "start": 2,
          "end": 3
        },
        {
          "text": "🚀",
          "normalizedText": "🚀",
          "type": "Symbol",
          "start": 3,
          "end": 5
        },
        {
          "text": "!",
          "normalizedText": "!",
          "type": "Punctuation",
          "start": 5,
          "end": 6
        }
      ]
    }
  ]
}