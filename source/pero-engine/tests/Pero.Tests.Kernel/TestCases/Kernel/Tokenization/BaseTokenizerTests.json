{
  "description": "Exhaustive tests for the language-agnostic BaseTokenizer. Focuses on exhaustive punctuation, Unicode symbols, surrogate pairs, and character boundaries.",
  "cases": [
    {
      "name": "Standard Sentence",
      "input": "Hello, world!",
      "expected": [
        {
          "text": "Hello",
          "normalizedText": "hello",
          "type": "Word",
          "start": 0,
          "end": 5
        },
        {
          "text": ",",
          "normalizedText": ",",
          "type": "Punctuation",
          "start": 5,
          "end": 6
        },
        {
          "text": " ",
          "normalizedText": " ",
          "type": "Whitespace",
          "start": 6,
          "end": 7
        },
        {
          "text": "world",
          "normalizedText": "world",
          "type": "Word",
          "start": 7,
          "end": 12
        },
        {
          "text": "!",
          "normalizedText": "!",
          "type": "Punctuation",
          "start": 12,
          "end": 13
        }
      ]
    },
    {
