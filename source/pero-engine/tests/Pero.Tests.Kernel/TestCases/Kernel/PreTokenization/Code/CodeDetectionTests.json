{
  "description": "Stress tests for detecting inline code snippets and code-like structures across 17+ programming languages.",
  "cases": [
    {
      "name": "C# / Java / TypeScript (C-Style)",
      "input": "Check this logic: if (isValid && count > 0) { return true; } else { return false; }",
      "expected": [
        {
          "type": "Raw",
          "text": "Check this logic: ",
          "start": 0,
          "end": 18
        },
        {
          "type": "CodeSnippet",
          "text": "if (isValid && count > 0) { return true; } else { return false; }",
          "start": 18,
          "end": 83
        }
      ]
    },
    {
      "name": "Python (Indentation & Snake_case)",
      "input": "Try this function: def calculate_sum(a, b):\n    return a + b",
      "expected": [
        {
          "type": "Raw",
          "text": "Try this function: ",
          "start": 0,
          "end": 19
        },
        {
          "type": "CodeSnippet",
          "text": "def calculate_sum(a, b):\n    return a + b",
          "start": 19,
          "end": 60
        }
      ]
    },
    {
      "name": "HTML / XML",
      "input": "Add a div here: <div class=\"container\" id=\"main\">Content</div>",
      "expected": [
        {
          "type": "Raw",
          "text": "Add a div here: ",
          "start": 0,
          "end": 16
        },
        {
          "type": "CodeSnippet",
          "text": "<div class=\"container\" id=\"main\">Content</div>",
          "start": 16,
          "end": 62
        }
      ]
    },
    {
      "name": "CSS / SCSS",
      "input": "Style it like this: .header { color: #333; margin-top: 10px; }",
      "expected": [
        {
          "type": "Raw",
          "text": "Style it like this: ",
          "start": 0,
          "end": 20
        },
        {
          "type": "CodeSnippet",
          "text": ".header { color: #333; margin-top: 10px; }",
          "start": 20,
          "end": 62
        }
      ]
    },
    {
      "name": "SQL",
      "input": "Run query: SELECT * FROM Users WHERE Age >= 18 AND Active = 1;",
      "expected": [
        {
          "type": "Raw",
          "text": "Run query: ",
          "start": 0,
          "end": 11
        },
        {
          "type": "CodeSnippet",
          "text": "SELECT * FROM Users WHERE Age >= 18 AND Active = 1;",
          "start": 11,
          "end": 62
        }
      ]
    },
    {
      "name": "Bash / Shell",
      "input": "Install dependencies: npm install --save-dev typescript && echo \"Done\"",
      "expected": [
        {
          "type": "Raw",
          "text": "Install dependencies: ",
          "start": 0,
          "end": 22
        },
        {
          "type": "CodeSnippet",
          "text": "npm install --save-dev typescript && echo \"Done\"",
          "start": 22,
          "end": 70
        }
      ]
    },
    {
      "name": "JSON Config",
      "input": "Config file: { \"name\": \"pero\", \"version\": \"1.0.0\" }",
      "expected": [
        {
          "type": "Raw",
