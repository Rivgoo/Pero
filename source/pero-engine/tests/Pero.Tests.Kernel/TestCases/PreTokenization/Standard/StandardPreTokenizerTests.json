{
  "description": "Exhaustive tests for StandardPreTokenizer. Includes deep FilePath edge cases and complex mixed entity scenarios.",
  "cases": [
    {
      "name": "Only Raw Text",
      "input": "Just a normal sentence with some punctuation!",
      "expected": [
        {
          "type": "Raw",
          "text": "Just a normal sentence with some punctuation!",
          "start": 0,
          "end": 45
        }
      ]
    },
    {
      "name": "Date Formats (Dots and Dashes)",
      "input": "Event is on 12.05.2024 or maybe 2024-05-13.",
      "expected": [
        {
          "type": "Raw",
          "text": "Event is on ",
          "start": 0,
          "end": 12
        },
        {
          "type": "Date",
          "text": "12.05.2024",
          "start": 12,
          "end": 22
        },
        {
          "type": "Raw",
          "text": " or maybe ",
          "start": 22,
          "end": 32
        },
        {
          "type": "Date",
          "text": "2024-05-13",
          "start": 32,
          "end": 42
        },
        {
          "type": "Raw",
          "text": ".",
          "start": 42,
          "end": 43
        }
      ]
    },
    {
