        {
          "type": "Time",
          "text": "14:30",
          "start": 11,
          "end": 16
        },
        {
          "type": "Raw",
          "text": " or ",
          "start": 16,
          "end": 20
        },
        {
          "type": "Time",
          "text": "08:00 AM",
          "start": 20,
          "end": 28
        },
        {
          "type": "Raw",
          "text": ".",
          "start": 28,
          "end": 29
        }
      ]
    },
