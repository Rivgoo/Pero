          "end": 49
        },
        {
          "type": "MacAddress",
          "text": "AA:BB:CC:DD:EE:FF",
          "start": 49,
          "end": 66
        },
        {
          "type": "Raw",
          "text": ").",
          "start": 66,
          "end": 68
        }
      ]
